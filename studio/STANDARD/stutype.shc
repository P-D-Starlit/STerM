$const(int64$short,  0x000C6010, ref, int64);
$const(int64$ushort, 0x000C7010, ref, int64);
$const(int64$char,   0x000C8010, ref, int64);

/// byte   A0   A2    A1    -    A3     B0   BB     C9    CA     CB
$const(byte$int,    0x000A0010, ref, byte);
$const(byte$float,  0x000A2010, ref, byte);
$const(byte$int64,  0x000A1010, ref, byte);
$const(byte$double, 0x000A3010, ref, byte);
$const(byte$uint,   0x000B0010, ref, byte);
$const(byte$uint64, 0x000BB010, ref, byte);
$const(byte$short,  0x000C9010, ref, byte);
$const(byte$ushort, 0x000CA010, ref, byte);
$const(byte$char,   0x000CB010, ref, byte);

/// double 57   5B    58    A7   -      B1   BC     CC    CD     CE
$const(double$int,    0x00057010, ref, double);
$const(double$float,  0x0005B010, ref, double);
$const(double$int64,  0x00058010, ref, double);
$const(double$byte,   0x000A7010, ref, double);
$const(double$uint,   0x000B1010, ref, double);
$const(double$uint64, 0x000BC010, ref, double);
$const(double$short,  0x000CC010, ref, double);
$const(double$ushort, 0x000CD010, ref, double);
$const(double$char,   0x000CE010, ref, double);

/// uint   A8   A9    AA    AB   AC     -    56     CF    D0     D1
$const(uint$int,    0x000A8010, ref, uint);
$const(uint$float,  0x000A9010, ref, uint);
$const(uint$int64,  0x000AA010, ref, uint);
$const(uint$byte,   0x000AB010, ref, uint);
