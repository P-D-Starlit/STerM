/// char   E7   E8    E9    EA   EB     EC   ED     EE    EF     -
$const(char$int,      0x000E7010, ref, char);
$const(char$float,    0x000E8010, ref, char);
$const(char$int64,    0x000E9010, ref, char);
$const(char$byte,     0x000EA010, ref, char);
