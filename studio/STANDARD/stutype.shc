$const(char$short,    0x000EE010, ref, char);
$const(char$ushort,   0x000EF010, ref, char);




///Ref
$const(val$ref,				0x00093010,		ref,	int		);
$const(int$ref,				0x00090010,		ref,	int		);
$const(int64$ref,			0x00091010,		ref,	int64	);
$const(float$ref,			0x00092010,		ref,	float	);
$const(double$ref,			0x00094010,		ref,	double	);
$const(uint$ref,			0x00095010,		ref,	uint	);
$const(uint64$ref,			0x00096010,		ref,	uint64	);
$const(short$ref,			0x00097010,		ref,	short	);
$const(ushort$ref,			0x00098010,		ref,	ushort	);
$const(char$ref,			0x00099010,		ref,	char	);
$const(byte$ref,			0x0009A010,		ref,	byte	);


$const(TRUE,                1,              int);
$const(FALSE,               0,              int);
$const(NULL,                0,              ref);