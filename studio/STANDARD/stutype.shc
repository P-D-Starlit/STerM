/// Starlit Type에 관한 정의

/// 기본 자료형의 관계

/// 기본 자료형
/// (0) int
/// (1) float
/// (2) ref
/// (3) int64
/// (4) byte
/// (5) double
/// (6) raw
/// (7) uint
/// (8) uint64
/// (9) short
/// (10) ushort
/// (11) char


/// 형변환 함수
/// 내장함수로 정의된 경우
///        int  float int64 byte double uint uint64 short ushort char (From)
/// int    -    50    55    A4   59     AD   B8     C0    C1     C2
/// float  53   -     54    A5   5C     AE   B9     C3    C4     C5
/// int64  52   51    -     A6   5A     AF   BA     C6    C7     C8
/// byte   A0   A2    A1    -    A3     B0   BB     C9    CA     CB
/// double 57   5B    58    A7   -      B1   BC     CC    CD     CE
/// uint   A8   A9    AA    AB   AC     -    56     CF    D0     D1
/// uint64 B2   B3    B4    B5   B6     B7   -      D2    D3     D4
/// short  D5   D6    D7    D8   D9     DA   DB     -     DC     DD
/// ushort DE   DF    E0    E1   E2     E3   E4     E5    -      E6
/// char   E7   E8    E9    EA   EB     EC   ED     EE    EF     -
/// (To)

/// int    -    50    55    A4   59     AD   B8     C0    C1     C2
$const(int$float,  0x00050010, ref, int);
$const(int$int64,  0x00055010, ref, int);
$const(int$byte,   0x000A4010, ref, int);
$const(int$double, 0x00059010, ref, int);
$const(int$uint,   0x000AD010, ref, int);
$const(int$uint64, 0x000B8010, ref, int);
$const(int$short,  0x000C0010, ref, int);
$const(int$ushort, 0x000C1010, ref, int);
$const(int$char,   0x000C2010, ref, int);

/// float  53   -     54    A5   5C     AE   B9     C3    C4     C5
$const(float$int,    0x00053010, ref, float);
$const(float$int64,  0x00054010, ref, float);
$const(float$byte,   0x000A5010, ref, float);
$const(float$double, 0x0005C010, ref, float);
$const(float$uint,   0x000AE010, ref, float);
$const(float$uint64, 0x000B9010, ref, float);
$const(float$short,  0x000C3010, ref, float);
$const(float$ushort, 0x000C4010, ref, float);
$const(float$char,   0x000C5010, ref, float);

/// int64  52   51    -     A6   5A     AF   BA     C6    C7     C8
$const(int64$int,    0x00052010, ref, int64);
$const(int64$float,  0x00051010, ref, int64);
$const(int64$byte,   0x000A6010, ref, int64);
