$const(uint$ushort, 0x000D0010, ref, uint);
$const(uint$char,   0x000D1010, ref, uint);

/// uint64 B2   B3    B4    B5   B6     B7   -      D2    D3     D4
$const(uint64$int,    0x000B2010, ref, uint64);
$const(uint64$float,  0x000B3010, ref, uint64);
$const(uint64$int64,  0x000B4010, ref, uint64);
$const(uint64$byte,   0x000B5010, ref, uint64);
$const(uint64$double, 0x000B6010, ref, uint64);
