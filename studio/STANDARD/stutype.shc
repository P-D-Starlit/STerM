$const(short$ushort, 0x000DC010, ref, short);
$const(short$char,   0x000DD010, ref, short);

/// ushort DE   DF    E0    E1   E2     E3   E4     E5    -      E6
$const(ushort$int,    0x000DE010, ref, ushort);
$const(ushort$float,  0x000DF010, ref, ushort);
$const(ushort$int64,  0x000E0010, ref, ushort);
$const(ushort$byte,   0x000E1010, ref, ushort);
