$const(uint64$ushort, 0x000D3010, ref, uint64);
$const(uint64$char,   0x000D4010, ref, uint64);

/// short  D5   D6    D7    D8   D9     DA   DB     -     DC     DD
$const(short$int,    0x000D5010, ref, short);
$const(short$float,  0x000D6010, ref, short);
$const(short$int64,  0x000D7010, ref, short);
$const(short$byte,   0x000D8010, ref, short);
$const(short$double, 0x000D9010, ref, short);
$const(short$uint,   0x000DA010, ref, short);
