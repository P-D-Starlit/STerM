$ltlt(x1:int, x2:int, x3:int):int{
    return(x1 < x2 && x2 < x3);
}
$lelt(x1:int, x2:int, x3:int):int{
    return(x1 <= x2 && x2 < x3);
}
$lele(x1:int, x2:int, x3:int):int{
    return(x1 <= x2 && x2 <= x3);
}
$ltle(x1:int, x2:int, x3:int):int{
    return(x1 < x2 && x2 <= x3);
}

$btbt(x1:int, x2:int, x3:int):int{
    return(x1 > x2 && x2 > x3);
}
$bebt(x1:int, x2:int, x3:int):int{
    return(x1 >= x2 && x2 > x3);
}
$bebe(x1:int, x2:int, x3:int):int{
    return(x1 >= x2 && x2 >= x3);
}
$btbe(x1:int, x2:int, x3:int):int{
    return(x1 > x2 && x2 >= x3);
}

$ltlt(x1:float, x2:float, x3:float):int{
    return(x1 < x2 && x2 < x3);
}
$lelt(x1:float, x2:float, x3:float):int{
    return(x1 <= x2 && x2 < x3);
}
$lele(x1:float, x2:float, x3:float):int{
    return(x1 <= x2 && x2 <= x3);
}
$ltle(x1:float, x2:float, x3:float):int{
    return(x1 < x2 && x2 <= x3);
}

$btbt(x1:float, x2:float, x3:float):int{
    return(x1 > x2 && x2 > x3);
}
$bebt(x1:float, x2:float, x3:float):int{
    return(x1 >= x2 && x2 > x3);
}
$bebe(x1:float, x2:float, x3:float):int{
    return(x1 >= x2 && x2 >= x3);
}
$btbe(x1:float, x2:float, x3:float):int{
    return(x1 > x2 && x2 >= x3);
}

$btbt(x1:double, x2:double, x3:double):int{
    return(x1 > x2 && x2 > x3);
}
$bebt(x1:double, x2:double, x3:double):int{
    return(x1 >= x2 && x2 > x3);
}
$bebe(x1:double, x2:double, x3:double):int{
    return(x1 >= x2 && x2 >= x3);
}
$btbe(x1:double, x2:double, x3:double):int{
