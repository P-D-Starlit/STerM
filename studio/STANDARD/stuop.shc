$eqeq(x1:int, x2:int, x3:int):int{
    return(x1 == x2 && x2 == x3);
}
$eqne(x1:int, x2:int, x3:int):int{
    return(x1 == x2 && x2 != x3);
}
$nene(x1:int, x2:int, x3:int):int{
    return(x1 != x2 && x2 != x3);
}
$neeq(x1:int, x2:int, x3:int):int{
    return(x1 != x2 && x2 == x3);
}





