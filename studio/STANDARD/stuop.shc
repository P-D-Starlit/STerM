$import(stutype);

///Default Constants : Bool Value and Truth.
$const(TRUE, 1, int);
$const(FALSE, 0, int);
$const(NULL, 0, ref);

///Defaultly, Starlit doesn't offers the unsigned type variable and short type(16-bit) variable.
///You may define studio for 16-bit and unsigned type if you want to use it.

///Previously, this pointer was the reference of self.
##this(self_);

///If I use the variable arguments, I have to define this class first.
$class(VA_LIST){
	#va:byte;
}

///Default For Structures
##for{x}from{a}to{b}(for({x}={a},{x}<={b},{x}={x}+1));
##else if(elif);
##{a}if{b}else{c}(if({b},{a},{c}));

svm_init(){
    Init();
}



///Single Term Operators

///Logical Not
$const($not$int,			0x00010010,		ref,	int		);
$const($not$int64,			0x00011010,		ref,	int		);


///Bitwise Not
$const($bnot$int,			0x00020010,		ref,	int		);
$const($bnot$int64,			0x00021010,		ref,	int64	);
$const($bnot$uint,			0x00020010,		ref,	uint	);
$const($bnot$uint64,		0x00021010,		ref,	uint64	);

///Minus
$const($minus$int,			0x00030010,		ref,	int		);
$const($minus$int64,		0x00031010,		ref,	int64	);
$const($minus$float,		0x00032010,		ref,	float	);
$const($minus$double,		0x00033010,		ref,	double	);

///Boolean
$const(Bool$int,			0x00040010,		ref,	int		);
$const(Bool$int64,			0x00041010,		ref,	int		);




///Double Term Operators
///Multiply
$const($mul$int$int,		0x01010010,		ref,	int		);
$const($mul$int64$int64,	0x01011010,		ref,	int64	);
$const($mul$uint$uint,		0x01013010,		ref,	uint	);
$const($mul$uint64$uint64,	0x01014010,		ref,	uint64	);
$const($mul$float$float,	0x01012010,		ref,	float	);
$const($mul$double$double,	0x01015010,		ref,	double	);
$mul(a:short, b:short )    :short   {return( short  (int(a)  * int(b) ) );}
$mul(a:ushort,b:ushort)    :ushort  {return( ushort (uint(a) * uint(b)) );}
$mul(a:char,  b:byte  )    :byte    {return( byte   (uint(a) * uint(b)) );}
$mul(a:char,  b:char  )    :char    {return( char   (int(a)  * int(b) ) );}


///Exponential
$const($exp$int$int,		0x0101A010,		ref,	int		);
$const($exp$int64$int64,	0x0101B010,		ref,	int64	);
$const($exp$uint$uint,		0x010F4010,		ref,	uint	);
$const($exp$uint64$uint64,	0x010F5010,		ref,	uint64	);
$const($exp$float$float,	0x0101C010,		ref,	float	);
$const($exp$double$double,	0x0300C010,		ref,	double	);

///Division
$const($div$int$int,		0x01020010,		ref,	int		);
$const($div$int64$int64,	0x01021010,		ref,	int64	);
$const($div$uint$uint,		0x01023010,		ref,	uint	);
$const($div$uint64$uint64,	0x01024010,		ref,	uint64	);
$const($div$float$float,	0x01022010,		ref,	float	);
$const($div$double$double,	0x01029010,		ref,	double	);
$div(a:short, b:short )    :short   {return( short  (int(a)  / int(b) ) );}
$div(a:ushort,b:ushort)    :ushort  {return( ushort (uint(a) / uint(b)) );}
$div(a:char,  b:byte  )    :byte    {return( byte   (uint(a) / uint(b)) );}
$div(a:char,  b:char  )    :char    {return( char   (int(a)  / int(b) ) );}


$div2(a:int, b:int):int{
    if(a < 0 && a %% b){
        return(a / b - 1);
    }
    else{
        return(a / b);
    }
}

$div2(a:int64, b:int64):int64{
    if(a < 0 && a %% b){
        return(a / b - 1);
    }
    else{
        return(a / b);
    }
}


///Modular
$const($mod$int$int,		0x01025010,		ref,	int		);
$const($mod$int64$int64,	0x01026010,		ref,	int64	);
$const($mod$uint$uint,		0x010F6010,		ref,	uint	);
$const($mod$uint64$uint64,	0x010F7010,		ref,	uint64	);
$mod(a:short, b:short )    :short   {return( short  (int(a)  % int(b) ) );}
$mod(a:ushort,b:ushort)    :ushort  {return( ushort (uint(a) % uint(b)) );}
$mod(a:char,  b:byte  )    :byte    {return( byte   (uint(a) % uint(b)) );}
$mod(a:char,  b:char  )    :char    {return( char   (int(a)  % int(b) ) );}


$mod2(a:int, b:int):int{
    result = a % b;
    if(result < 0){
        result += b;
    }
    return(result);
}

$mod2(a:int64, b:int64):int64{
    result = a % b;
    if(result < 0){
        result += b;
    }
    return(result);
}

