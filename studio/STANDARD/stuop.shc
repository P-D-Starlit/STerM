}



$ltltlt(x1:int, x2:int, x3:int, x4:int):int{
    return(x1 < x2 && x2 < x3 && x3 < x4);
}
$ltltle(x1:int, x2:int, x3:int, x4:int):int{
    return(x1 < x2 && x2 < x3 && x3 <= x4);
}
$ltlele(x1:int, x2:int, x3:int, x4:int):int{
    return(x1 < x2 && x2 <= x3 && x3 <= x4);
}
$ltlelt(x1:int, x2:int, x3:int, x4:int):int{
    return(x1 < x2 && x2 <= x3 && x3 < x4);
}
$lelelt(x1:int, x2:int, x3:int, x4:int):int{
    return(x1 <= x2 && x2 <= x3 && x3 < x4);
}
$lelele(x1:int, x2:int, x3:int, x4:int):int{
    return(x1 <= x2 && x2 <= x3 && x3 <= x4);
}
$leltle(x1:int, x2:int, x3:int, x4:int):int{
    return(x1 <= x2 && x2 < x3 && x3 <= x4);
}
$leltlt(x1:int, x2:int, x3:int, x4:int):int{
    return(x1 <= x2 && x2 < x3 && x3 < x4);
}

$btbtbt(x1:int, x2:int, x3:int, x4:int):int{
    return(x1 > x2 && x2 > x3 && x3 > x4);
}
$btbtbe(x1:int, x2:int, x3:int, x4:int):int{
    return(x1 > x2 && x2 > x3 && x3 >= x4);
}
$btbebe(x1:int, x2:int, x3:int, x4:int):int{
    return(x1 > x2 && x2 >= x3 && x3 >= x4);
}
$btbebt(x1:int, x2:int, x3:int, x4:int):int{
    return(x1 > x2 && x2 >= x3 && x3 > x4);
}
$bebebt(x1:int, x2:int, x3:int, x4:int):int{
    return(x1 >= x2 && x2 >= x3 && x3 > x4);
}
$bebebe(x1:int, x2:int, x3:int, x4:int):int{
    return(x1 >= x2 && x2 >= x3 && x3 >= x4);
}
$bebtbe(x1:int, x2:int, x3:int, x4:int):int{
    return(x1 >= x2 && x2 > x3 && x3 >= x4);
}
$bebtbt(x1:int, x2:int, x3:int, x4:int):int{
    return(x1 >= x2 && x2 > x3 && x3 > x4);
}






